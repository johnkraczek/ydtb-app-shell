{
  "name": "@ydtb/tk-scope-ui",
  "version": "0.14.7",
  "private": false,
  "description": "",
  "type": "module",
  "license": "UNLICENSED",
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    ".": {
      "dev-src": "./src/index.ts",
      "types": "./dist/src/index.d.ts",
      "default": "./dist/src/index.js"
    },
    "./tags": {
      "dev-src": "./src/tags.ts",
      "types": "./dist/src/tags.d.ts",
      "default": "./dist/src/tags.js"
    },
    "./testing": {
      "dev-src": "./testing/index.ts",
      "types": "./dist/testing/index.d.ts",
      "default": "./dist/testing/index.js"
    },
    "./components/data-table": {
      "dev-src": "./src/components/data-table/index.ts",
      "types": "./dist/src/components/data-table/index.d.ts",
      "default": "./dist/src/components/data-table/index.js"
    },
    "./components/icon-picker": {
      "dev-src": "./src/components/icon-picker/index.ts",
      "types": "./dist/src/components/icon-picker/index.d.ts",
      "default": "./dist/src/components/icon-picker/index.js"
    },
    "./components/settings": {
      "dev-src": "./src/components/settings/index.ts",
      "types": "./dist/src/components/settings/index.d.ts",
      "default": "./dist/src/components/settings/index.js"
    },
    "./components/*": {
      "dev-src": "./src/components/*.tsx",
      "types": "./dist/src/components/*.d.ts",
      "default": "./dist/src/components/*.js"
    },
    "./lib/*": {
      "dev-src": "./src/lib/*.ts",
      "types": "./dist/src/lib/*.d.ts",
      "default": "./dist/src/lib/*.js"
    },
    "./styles/*": "./src/styles/*",
    "./styles": {
      "dev-src": "./src/styles/globals.css",
      "default": "./src/styles/globals.css"
    }
  },
  "files": [
    "src",
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -b",
    "typecheck": "tsc -b --noEmit",
    "lint": "eslint .",
    "test": "vitest run",
    "clean": "rm -rf dist *.tsbuildinfo"
  },
  "dependencies": {
    "@base-ui/react": "^1.3.0",
    "@ydtb/tk-scope": "workspace:*",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-avatar": "^1.1.0",
    "@radix-ui/react-checkbox": "^1.1.0",
    "@radix-ui/react-dialog": "^1.1.0",
    "@radix-ui/react-dropdown-menu": "^2.1.0",
    "@radix-ui/react-label": "^2.1.0",
    "@radix-ui/react-popover": "^1.1.0",
    "@radix-ui/react-scroll-area": "^1.1.0",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-slot": "^1.1.0",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.0",
    "@radix-ui/react-tooltip": "^1.1.0",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.0",
    "date-fns": "^4.1.0",
    "radix-ui": "^1.4.3",
    "react-day-picker": "^9.14.0",
    "react-easy-crop": "^5.5.7",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.4.0"
  },
  "peerDependencies": {
    "tailwindcss": "^4.0.0",
    "react": ">=19.0.0",
    "react-dom": ">=19.0.0",
    "lucide-react": ">=0.400.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^19.0.8",
    "@types/react-dom": "^19.0.0",
    "eslint": "^10.0.0",
    "jsdom": "^29.0.2",
    "prettier": "^3.8.0",
    "typescript": "^5.7.0",
    "vitest": "^4.1.0"
  }
}
